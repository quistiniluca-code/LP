  <script>
    (function(){
      const root = document.querySelector('.econ-lp-v6');
      if(!root) return;

      const segBtns = root.querySelectorAll('.seg-btn');
      const usageBtns = root.querySelectorAll('[data-usage]');
      const extraBtns = root.querySelectorAll('[data-extra]');
      const range = root.querySelector('#billRange');

      let profile = 'home';
      let usage = 'day';
      const extras = {heat:false, ev:false, battery:false};

      const billLabel = root.querySelector('#billLabel');
      const scoreLabel = root.querySelector('#scoreLabel');
      const scoreText = root.querySelector('#scoreText');
      const sizeLabel = root.querySelector('#sizeLabel');
      const sizeText = root.querySelector('#sizeText');
      const saveLabel = root.querySelector('#saveLabel');
      const paybackLabel = root.querySelector('#paybackLabel');
      const summaryLabel = root.querySelector('#summaryLabel');
      const summaryText = root.querySelector('#summaryText');

      function fmtEuro(v){
        return new Intl.NumberFormat('it-IT').format(Math.round(v));
      }

      function compute(){
        const bill = parseInt(range.value, 10);

        let size = profile === 'craft' ? bill / 520 : bill / 430;

        if (usage === 'evening') size *= 0.88;
        if (usage === 'mixed') size *= 0.96;
        if (extras.heat) size += profile === 'craft' ? 0.5 : 1.2;
        if (extras.ev) size += 1.2;
        if (extras.battery && usage !== 'day') size += 0.3;

        size = Math.max(profile === 'craft' ? 5 : 3, Math.min(profile === 'craft' ? 18 : 12, size));
        size = Math.round(size * 2) / 2;

        let saveRatio = profile === 'craft' ? 0.52 : 0.47;
        if (usage === 'day') saveRatio += 0.08;
        if (usage === 'mixed') saveRatio += 0.03;
        if (usage === 'evening') saveRatio -= 0.05;
        if (extras.battery && usage !== 'day') saveRatio += 0.05;
        if (extras.heat) saveRatio += 0.02;

        saveRatio = Math.max(0.28, Math.min(0.66, saveRatio));

        const annualSave = bill * saveRatio;

        let invest = size * (profile === 'craft' ? 1180 : 1350);
        if (extras.battery) invest += 3200;

        let payback = invest / Math.max(annualSave, 1);
        payback = Math.max(3.8, Math.min(11.5, payback));

        let score = 'Media';
        let scoreMsg = 'Profilo da verificare con attenzione.';

        if (annualSave > 1200 && payback < 7.5) {
          score = 'Alta';
          scoreMsg = 'Profilo con buona convenienza e rientro ordinato.';
        }

        if (annualSave > 2200 && payback < 6) {
          score = 'Molto alta';
          scoreMsg = 'Profilo molto favorevole, soprattutto se i consumi sono diurni.';
        }

        if (annualSave < 850 || payback > 9) {
          score = 'Da calibrare';
          scoreMsg = 'Il caso può avere senso, ma solo con taglia e aspettative ben misurate.';
        }

        billLabel.textContent = fmtEuro(bill);
        sizeLabel.textContent = size.toFixed(1).replace('.', ',') + ' kWp';
        sizeText.textContent = profile === 'craft'
          ? 'Taglia pensata per un uso diurno regolare.'
          : 'Impianto calibrato sul profilo dichiarato.';
        saveLabel.textContent = fmtEuro(annualSave) + ' €';
        paybackLabel.textContent = payback.toFixed(1).replace('.', ',') + ' anni';
        scoreLabel.textContent = score;
        scoreText.textContent = scoreMsg;

        if(score === 'Molto alta'){
          summaryLabel.textContent = 'Caso molto adatto a un approfondimento';
          summaryText.textContent = 'Il profilo dichiarato lascia spazio a una proposta forte, con buona probabilità di rientro ordinato.';
        } else if(score === 'Alta'){
          summaryLabel.textContent = 'Caso adatto a un approfondimento';
          summaryText.textContent = 'La spesa e il modo di consumare indicano un potenziale interessante da sviluppare in dossier.';
        } else {
          summaryLabel.textContent = 'Caso da leggere con precisione';
          summaryText.textContent = 'Serve prudenza sulla taglia e sulle attese di risparmio. Il dossier è utile proprio per questo.';
        }
      }

      segBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          segBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          profile = btn.dataset.profile;
          compute();
        });
      });

      usageBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          usageBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          usage = btn.dataset.usage;
          compute();
        });
      });

      extraBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const key = btn.dataset.extra;
          extras[key] = !extras[key];
          btn.classList.toggle('active', extras[key]);
          compute();
        });
      });

      range.addEventListener('input', compute);
      compute();

      const dossierTabs = root.querySelectorAll('.dossier-tab');
      const dossierPanels = root.querySelectorAll('.dossier-panel');
      const pages = root.querySelectorAll('.page');

      dossierTabs.forEach((tab, idx) => {
        tab.addEventListener('click', () => {
          dossierTabs.forEach(t => t.classList.remove('active'));
          dossierPanels.forEach(p => p.classList.remove('active'));
          pages.forEach(p => p.classList.remove('active'));

          tab.classList.add('active');
          root.querySelector('#' + tab.dataset.target).classList.add('active');

          const page = pages[idx] || pages[0];
          if(page) page.classList.add('active');
        });
      });

      const caseBtns = root.querySelectorAll('.case-btn');
      const casePanels = root.querySelectorAll('.case-panel');

      caseBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          caseBtns.forEach(b => b.classList.remove('active'));
          casePanels.forEach(p => p.classList.remove('active'));

          btn.classList.add('active');
          const panel = root.querySelector('#' + btn.dataset.case);
          if(panel) panel.classList.add('active');
        });
      });
    })();
  </script>
