<!DOCTYPE html>
<html lang="en">
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sustainable Energy Platform</title>
    <link href="https://fonts.googleapis.com/css2?family=Arimo:wght@400&display=swap" rel="stylesheet">
    <title>ECONSYSTEM | Transizione Energetica Intelligente</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Arimo:wght@400;600;700&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-dark': '#043D00',
                        'brand-light': '#8DC63F',
                        'brand-white': '#FFFFFF',
                    },
                    fontFamily: {
                        'arimo': ['Arimo', 'sans-serif'],
                    },
                    letterSpacing: {
                        'tightest': '-.05em',
                    },
                    borderRadius: {
                        '4xl': '2.5rem',
                        'pill': '9999px',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Arimo', sans-serif;
            background-color: #FFFFFF;
            color: #043D00;
        }
        .header {
            background-color: #8DC63F;
            padding: 20px;
            text-align: center;
        }
        .methodology {
            margin: 20px;
        }
        .diagnosis {
            margin: 20px;
            padding: 10px;
            background-color: #e6ffe6;
        }
        .features {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin: 20px;
        }
        .feature {
            border: 1px solid #8DC63F;
            padding: 10px;
            text-align: center;
        }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #FFFFFF; }
        ::-webkit-scrollbar-thumb { background: #043D00; border-radius: 4px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Welcome to the Sustainable Energy Platform</h1>
<section class="econ-lp-v6" id="econ-top">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Arimo:wght@400;600;700;800&display=swap');

    .econ-lp-v6{
      --verde-scuro:#043D00;
      --verde-chiaro:#8DC63F;
      --bianco:#FFFFFF;
      --fondo-chiaro:#F3F7EE;
      --fondo-chiaro-2:#EAF2E1;
      --linea:rgba(4,61,0,.12);
      --ombra:0 20px 50px rgba(4,61,0,.10);
      --ombra-forte:0 30px 70px rgba(0,0,0,.16);
      --r1:18px;
      --r2:24px;
      --r3:34px;
      --r4:42px;
      --max:1240px;
      font-family:'Arimo',sans-serif;
      color:var(--verde-scuro);
      background:var(--bianco);
      line-height:1.5;
    }

    .econ-lp-v6 *,.econ-lp-v6 *:before,.econ-lp-v6 *:after{box-sizing:border-box}
    .econ-lp-v6 a{text-decoration:none;color:inherit}
    .econ-lp-v6 img{display:block;max-width:100%}
    .econ-lp-v6 .wrap{width:min(var(--max),calc(100% - 40px));margin:0 auto}
    .econ-lp-v6 .section{padding:88px 0}

    .econ-lp-v6 h1,
    .econ-lp-v6 h2,
    .econ-lp-v6 h3,
    .econ-lp-v6 h4{
      margin:0;
      text-transform:uppercase;
      letter-spacing:-.04em;
      line-height:.96;
      font-weight:800;
    }

    .econ-lp-v6 h1{font-size:clamp(42px,6.2vw,84px);max-width:780px}
    .econ-lp-v6 h2{font-size:clamp(32px,4vw,58px);max-width:860px}
    .econ-lp-v6 h3{font-size:clamp(22px,2vw,30px)}
    .econ-lp-v6 p{margin:0;font-size:16px}
    .econ-lp-v6 .lead{font-size:clamp(18px,1.9vw,21px);max-width:760px}

    .econ-lp-v6 .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:10px 16px;
      border-radius:999px;
      background:rgba(141,198,63,.16);
      color:var(--verde-scuro);
      font-size:12px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.11em;
    }

    .econ-lp-v6 .eyebrow.white{
      background:rgba(255,255,255,.12);
      color:var(--bianco);
      border:1px solid rgba(255,255,255,.12);
    }

    .econ-lp-v6 .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      min-height:54px;
      padding:15px 24px;
      border-radius:999px;
      font:inherit;
      font-size:13px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.08em;
      cursor:pointer;
      border:0;
      transition:transform .18s ease,background .18s ease,color .18s ease,box-shadow .18s ease;
    }

    .econ-lp-v6 .btn:hover{transform:translateY(-2px)}
    .econ-lp-v6 .btn-dark{background:var(--verde-scuro);color:var(--bianco)}
    .econ-lp-v6 .btn-lime{background:var(--verde-chiaro);color:var(--bianco)}
    .econ-lp-v6 .btn-white{background:var(--bianco);color:var(--verde-scuro);box-shadow:var(--ombra)}

    .econ-lp-v6 .topbar{
      position:sticky;
      top:0;
      z-index:40;
      background:rgba(255,255,255,.94);
      backdrop-filter:blur(12px);
      border-bottom:1px solid var(--linea);
    }

    .econ-lp-v6 .topbar-inner{
      min-height:84px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:18px;
    }

    .econ-lp-v6 .brand{
      display:flex;
      align-items:center;
      gap:14px;
    }

    .econ-lp-v6 .brand img{
      width:58px;
      height:58px;
      object-fit:contain;
      border-radius:12px;
      background:transparent;
    }

    .econ-lp-v6 .brand strong{
      display:block;
      font-size:23px;
      letter-spacing:-.04em;
      line-height:1;
    }

    .econ-lp-v6 .brand span{
      display:block;
      margin-top:6px;
      font-size:11px;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.16em;
      opacity:.72;
    }

    .econ-lp-v6 .menu{
      display:flex;
      align-items:center;
      gap:22px;
      font-size:13px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.06em;
    }

    .econ-lp-v6 .hero{
      position:relative;
      background:var(--verde-scuro);
      color:var(--bianco);
      overflow:hidden;
      padding:24px 0 0;
    }

    .econ-lp-v6 .hero:before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(130deg, rgba(6,40,5,.8) 0%, rgba(4,61,0,.1) 55%, rgba(141,198,63,.14) 100%),
        radial-gradient(circle at 12% 16%, rgba(141,198,63,.11), transparent 18%),
        radial-gradient(circle at 84% 18%, rgba(141,198,63,.10), transparent 14%),
        repeating-linear-gradient(115deg, rgba(141,198,63,.12) 0 2px, transparent 2px 20px);
      pointer-events:none;
    }

    .econ-lp-v6 .hero:after{
      content:"";
      position:absolute;
      right:-120px;
      bottom:-140px;
      width:480px;
      height:480px;
      border-radius:50%;
      background:
        radial-gradient(circle at 30% 30%, rgba(233,245,194,.58), rgba(141,198,63,.14) 48%, transparent 72%),
        conic-gradient(from 180deg, rgba(141,198,63,.25), rgba(255,255,255,0) 38%, rgba(141,198,63,.18) 76%, rgba(141,198,63,.25));
      filter:blur(.4px);
      pointer-events:none;
    }

    .econ-lp-v6 .hero-visual{
      position:absolute;
      right:0;
      top:0;
      width:min(44vw,680px);
      opacity:.22;
      transform:translate(10%,-6%);
      pointer-events:none;
    }

    .econ-lp-v6 .hero-grid{
      display:grid;
      grid-template-columns:1.04fr .96fr;
      gap:30px;
      align-items:center;
      min-height:calc(100vh - 110px);
      position:relative;
      z-index:1;
      padding:40px 0 52px;
    }

    .econ-lp-v6 .hero-copy{
      display:flex;
      flex-direction:column;
      gap:24px;
    }

    .econ-lp-v6 .hero-copy p{color:rgba(255,255,255,.9)}

    .econ-lp-v6 .hero-list{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:14px;
    }

    .econ-lp-v6 .hero-item{
      padding:18px;
      border-radius:var(--r1);
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.10);
    }

    .econ-lp-v6 .hero-item strong{
      display:block;
      margin-bottom:8px;
      font-size:12px;
      text-transform:uppercase;
      letter-spacing:.12em;
      color:var(--verde-chiaro);
    }

    .econ-lp-v6 .hero-badges{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    .econ-lp-v6 .hero-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.22);
      background:rgba(255,255,255,.1);
      font-size:12px;
      font-weight:700;
      letter-spacing:.04em;
      text-transform:uppercase;
    }

    .econ-lp-v6 .hero-badge .glyph{
      width:18px;
      height:18px;
      display:grid;
      place-items:center;
      border-radius:50%;
      background:rgba(141,198,63,.32);
      font-size:11px;
    }

    .econ-lp-v6 .hero-actions{
      display:flex;
      flex-wrap:wrap;
      gap:14px;
    }

    .econ-lp-v6 .engine{
      background:var(--bianco);
      color:var(--verde-scuro);
      border-radius:var(--r4);
      padding:28px;
      box-shadow:var(--ombra-forte);
      position:relative;
      overflow:hidden;
    }

    .econ-lp-v6 .engine:before{
      content:"";
      position:absolute;
      right:-60px;
      top:-56px;
      width:180px;
      height:180px;
      border:2px solid rgba(4,61,0,.08);
      border-radius:30px;
      transform:rotate(45deg);
    }

    .econ-lp-v6 .engine-head{
      display:grid;
      grid-template-columns:1fr auto;
      gap:14px;
      align-items:start;
      margin-bottom:18px;
      position:relative;
      z-index:1;
    }

    .econ-lp-v6 .engine-head p{
      font-size:15px;
      color:rgba(4,61,0,.72);
      max-width:430px;
    }

    .econ-lp-v6 .tag{
      display:inline-flex;
      padding:10px 14px;
      border-radius:999px;
      background:var(--verde-chiaro);
      color:var(--bianco);
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.12em;
    }

    .econ-lp-v6 .segmented,
    .econ-lp-v6 .toggle-row,
    .econ-lp-v6 .check-row,
    .econ-lp-v6 .dossier-tabs,
    .econ-lp-v6 .case-tabs{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }

    .econ-lp-v6 .segmented{margin-bottom:16px}

    .econ-lp-v6 .chip,
    .econ-lp-v6 .seg-btn,
    .econ-lp-v6 .dossier-tab,
    .econ-lp-v6 .case-tab{
      padding:12px 16px;
      border-radius:999px;
      background:var(--fondo-chiaro);
      border:1px solid var(--linea);
      font-size:13px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.06em;
      cursor:pointer;
      transition:all .18s ease;
    }

    .econ-lp-v6 .chip.active,
    .econ-lp-v6 .seg-btn.active,
    .econ-lp-v6 .dossier-tab.active,
    .econ-lp-v6 .case-tab.active{
      background:var(--verde-scuro);
      color:var(--bianco);
      border-color:var(--verde-scuro);
    }

    .econ-lp-v6 .range-box{
      background:var(--fondo-chiaro);
      border:1px solid var(--linea);
      border-radius:var(--r2);
      padding:18px;
      margin-bottom:16px;
    }

    .econ-lp-v6 .range-meta{
      display:flex;
      justify-content:space-between;
      gap:14px;
      align-items:flex-end;
      margin-bottom:12px;
    }

    .econ-lp-v6 .range-meta small,
    .econ-lp-v6 .kpi small,
    .econ-lp-v6 .metric small,
    .econ-lp-v6 .doc-table small,
    .econ-lp-v6 .case-num small,
    .econ-lp-v6 .benefit small{
      display:block;
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.12em;
      opacity:.66;
      margin-bottom:7px;
    }

    .econ-lp-v6 .range-meta strong{
      display:block;
      font-size:40px;
      line-height:1;
      letter-spacing:-.05em;
    }

    .econ-lp-v6 input[type=range]{
      width:100%;
      appearance:none;
      background:transparent;
    }

    .econ-lp-v6 input[type=range]::-webkit-slider-runnable-track{
      height:12px;
      background:#d9e7cd;
      border-radius:999px;
    }

    .econ-lp-v6 input[type=range]::-moz-range-track{
      height:12px;
      background:#d9e7cd;
      border-radius:999px;
    }

    .econ-lp-v6 input[type=range]::-webkit-slider-thumb{
      appearance:none;
      width:28px;
      height:28px;
      border-radius:50%;
      background:var(--verde-scuro);
      border:4px solid var(--verde-chiaro);
      margin-top:-8px;
      cursor:pointer;
    }

    .econ-lp-v6 input[type=range]::-moz-range-thumb{
      width:28px;
      height:28px;
      border-radius:50%;
      background:var(--verde-scuro);
      border:4px solid var(--verde-chiaro);
      cursor:pointer;
    }

    .econ-lp-v6 .kpis{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:14px;
    }

    .econ-lp-v6 .kpi{
      background:var(--fondo-chiaro);
      border:1px solid var(--linea);
      border-radius:var(--r2);
      padding:18px;
    }

    .econ-lp-v6 .kpi.dark{
      background:var(--verde-scuro);
      color:var(--bianco);
      border-color:var(--verde-scuro);
    }

    .econ-lp-v6 .kpi.wide{grid-column:1 / -1}

    .econ-lp-v6 .kpi strong{
      display:block;
      font-size:clamp(28px,2.7vw,40px);
      line-height:1;
      letter-spacing:-.05em;
    }

    .econ-lp-v6 .kpi p{
      margin-top:10px;
      font-size:14px;
      color:rgba(4,61,0,.74);
    }

    .econ-lp-v6 .kpi.dark p{color:rgba(255,255,255,.78)}
    .econ-lp-v6 .engine-note{margin-top:14px;font-size:12px;color:rgba(4,61,0,.56)}

    .econ-lp-v6 .proof{
      background:#081808;
      color:var(--bianco);
      border-top:1px solid rgba(255,255,255,.08);
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .econ-lp-v6 .proof-grid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:0;
    }

    .econ-lp-v6 .proof-card{
      padding:20px 18px;
      border-left:1px solid rgba(255,255,255,.08);
    }

    .econ-lp-v6 .proof-card:first-child{border-left:0}

    .econ-lp-v6 .proof-card strong{
      display:block;
      color:var(--verde-chiaro);
      margin-bottom:8px;
      font-size:13px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.12em;
    }

    .econ-lp-v6 .proof-icon{
      display:inline-grid;
      place-items:center;
      width:30px;
      height:30px;
      margin-bottom:10px;
      border-radius:10px;
      background:rgba(141,198,63,.18);
      border:1px solid rgba(141,198,63,.35);
      font-size:15px;
    }

    .econ-lp-v6 .split-head{
      display:grid;
      grid-template-columns:1.05fr .95fr;
      gap:24px;
      align-items:end;
      margin-bottom:34px;
    }

    .econ-lp-v6 .split-head p{
      max-width:560px;
      color:rgba(4,61,0,.74);
    }

    .econ-lp-v6 .steps-band{background:var(--verde-chiaro)}

    .econ-lp-v6 .step-grid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:18px;
    }

    .econ-lp-v6 .step{padding:6px 0 12px}

    .econ-lp-v6 .step .num{
      font-size:clamp(56px,7vw,94px);
      line-height:.88;
      letter-spacing:-.05em;
      font-weight:800;
      margin-bottom:12px;
    }

    .econ-lp-v6 .step p{
      font-size:17px;
      font-weight:600;
      max-width:320px;
    }

    .econ-lp-v6 .dossier-layout{
      display:grid;
      grid-template-columns:.94fr 1.06fr;
      gap:28px;
      align-items:stretch;
    }

    .econ-lp-v6 .dossier-shell{
      background:var(--verde-scuro);
      border-radius:var(--r4);
      padding:28px;
      position:relative;
      overflow:hidden;
      min-height:620px;
    }

    .econ-lp-v6 .dossier-shell:before{
      content:"";
      position:absolute;
      left:-90px;
      bottom:-90px;
      width:220px;
      height:220px;
      border-radius:50%;
      background:rgba(255,255,255,.08);
    }

    .econ-lp-v6 .stack{
      position:relative;
      width:min(100%,430px);
      height:490px;
      margin:22px auto 0;
    }

    .econ-lp-v6 .page{
      position:absolute;
      inset:0;
      background:var(--bianco);
      border-radius:28px;
      padding:22px;
      box-shadow:0 16px 40px rgba(0,0,0,.18);
      transition:transform .25s ease,opacity .25s ease;
      opacity:.64;
      transform:translateY(18px) scale(.98);
    }

    .econ-lp-v6 .page.p1{transform:rotate(-5deg) translate(-18px,22px)}
    .econ-lp-v6 .page.p2{transform:rotate(4deg) translate(12px,10px)}
    .econ-lp-v6 .page.p3{transform:rotate(0deg) translate(0,0)}
    .econ-lp-v6 .page.active{opacity:1;z-index:3}

    .econ-lp-v6 .doc-head{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
      margin-bottom:16px;
    }

    .econ-lp-v6 .doc-head strong{
      font-size:26px;
      line-height:.92;
      letter-spacing:-.04em;
      text-transform:uppercase;
    }

    .econ-lp-v6 .mini{
      display:inline-flex;
      padding:8px 12px;
      border-radius:999px;
      background:var(--fondo-chiaro-2);
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.08em;
    }

    .econ-lp-v6 .doc-project{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
      padding:14px;
      border-radius:18px;
      background:var(--fondo-chiaro);
      border:1px solid var(--linea);
      margin-bottom:14px;
    }

    .econ-lp-v6 .doc-project strong{
      display:block;
      font-size:17px;
      line-height:1.15;
      letter-spacing:-.02em;
      text-transform:none;
    }

    .econ-lp-v6 .doc-project span{
      display:block;
      margin-top:4px;
      font-size:13px;
      color:rgba(4,61,0,.66);
    }

    .econ-lp-v6 .doc-badge{
      display:inline-flex;
      align-items:center;
      padding:10px 12px;
      border-radius:999px;
      background:var(--verde-scuro);
      color:var(--bianco);
      font-size:11px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.08em;
      white-space:nowrap;
    }

    .econ-lp-v6 .metric{
      padding:14px;
      border-radius:18px;
      background:var(--fondo-chiaro);
      border:1px solid var(--linea);
      margin-bottom:14px;
    }

    .econ-lp-v6 .metric strong{
      display:block;
      font-size:28px;
      line-height:1;
      letter-spacing:-.04em;
    }

    .econ-lp-v6 .doc-row{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
      margin-bottom:14px;
    }

    .econ-lp-v6 .doc-table{
      padding:14px;
      border-radius:16px;
      background:var(--bianco);
      border:1px solid var(--linea);
    }

    .econ-lp-v6 .doc-table strong{
      display:block;
      font-size:20px;
      line-height:1;
    }

    .econ-lp-v6 .bar-group{display:grid;gap:10px}

    .econ-lp-v6 .bar-line{
      display:grid;
      grid-template-columns:1fr auto;
      gap:10px;
      align-items:center;
    }

    .econ-lp-v6 .bar{
      height:12px;
      border-radius:999px;
      background:#dbe8d1;
      overflow:hidden;
    }

    .econ-lp-v6 .bar > span{
      display:block;
      height:100%;
      background:var(--verde-chiaro);
      border-radius:999px;
    }

    .econ-lp-v6 .aside-card{
